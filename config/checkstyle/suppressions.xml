<?xml version="1.0"?>
<!DOCTYPE suppressions PUBLIC
    "-//Checkstyle//DTD SuppressionFilter Configuration 1.2//EN"
    "https://checkstyle.org/dtds/suppressions_1_2.dtd">

<!--
    SuppressionFilter can suppress audit events between certain lines.
    It can also suppress audit events in files that match a file pattern.

    The format of this file is specified at
    https://checkstyle.org/config_filters.html#SuppressionFilter.

    Suppression is done via 'checks' attribute, which is a
    comma-separated list of check names to suppress.

    You can find the name of the check by looking at the error message
    from Checkstyle. For example, the message "Missing a Javadoc comment"
    corresponds to the check name "JavadocMethod".

    You can also use the check name as defined in the Checkstyle source
    code, such as "com.puppycrawl.tools.checkstyle.checks.javadoc.JavadocMethod".

    You can suppress JavaDoc checks for files that are generated or should not
    follow JavaDoc conventions by adding entries to this file.
-->

<suppressions>
    <!-- Suppress JavadocMethod check for main method -->
    <suppress files=".*\.java" checks="JavadocMethod" lines="1-100"/>
    
    <!-- Suppress JavadocType check for simple classes -->
    <suppress files=".*\.java" checks="JavadocType" lines="1-50"/>
    
    <!-- Suppress JavadocVariable check for simple fields -->
    <suppress files=".*\.java" checks="JavadocVariable" lines="1-50"/>
    
    <!-- Suppress MagicNumber check for test files -->
    <suppress files=".*Test\.java" checks="MagicNumber"/>
    
    <!-- Suppress MissingJavadocMethod for simple getters/setters -->
    <suppress files=".*\.java" checks="MissingJavadocMethod" lines="1-200"/>
    
    <!-- Suppress package-info.java requirement -->
    <suppress files=".*\.java" checks="JavadocPackage"/>
    
    <!-- Suppress utility class constructor warnings -->
    <suppress files=".*\.java" checks="HideUtilityClassConstructor"/>
    
    <!-- Suppress design for extension warnings -->
    <suppress files=".*\.java" checks="DesignForExtension"/>
    
    <!-- Suppress nested blocks warnings -->
    <suppress files=".*\.java" checks="AvoidNestedBlocks"/>
    
    <!-- Suppress missing switch default warnings -->
    <suppress files=".*\.java" checks="MissingSwitchDefault"/>
    
    <!-- Suppress import order warnings -->
    <suppress files=".*\.java" checks="ImportOrder"/>
    
    <!-- Suppress hidden field warnings -->
    <suppress files=".*\.java" checks="HiddenField"/>
    
    <!-- Suppress visibility modifier warnings -->
    <suppress files=".*\.java" checks="VisibilityModifier"/>
    
    <!-- Suppress newline at end of file warnings -->
    <suppress files=".*\.java" checks="NewlineAtEndOfFile"/>
    
    <!-- Suppress final parameters warnings -->
    <suppress files=".*\.java" checks="FinalParameters"/>
    
    <!-- Suppress need braces warnings -->
    <suppress files=".*\.java" checks="NeedBraces"/>
</suppressions>
