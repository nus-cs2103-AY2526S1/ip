<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="Note.GUI.MainWindow"
            prefHeight="400.0" prefWidth="600.0">

    <children>
        <!-- Scrollable dialog area -->
        <ScrollPane fx:id="scrollPane" fitToWidth="true"
                    AnchorPane.topAnchor="1.0"
                    AnchorPane.leftAnchor="1.0"
                    AnchorPane.rightAnchor="1.0"
                    AnchorPane.bottomAnchor="50.0">
            <content>
                <VBox fx:id="dialogContainer" spacing="10.0"/>
            </content>
        </ScrollPane>

        <!-- User input field -->
        <TextField fx:id="userInput" prefHeight="30.0"
                   AnchorPane.leftAnchor="1.0"
                   AnchorPane.rightAnchor="80.0"
                   AnchorPane.bottomAnchor="10.0"/>

        <!-- Send button -->
        <Button fx:id="sendButton" text="Send"
                onAction="#handleUserInput"
                AnchorPane.rightAnchor="10.0"
                AnchorPane.bottomAnchor="10.0"/>
    </children>
</AnchorPane>
