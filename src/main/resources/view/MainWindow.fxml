<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="600.0" prefWidth="400.0"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="jooh.gui.MainWindow">
    <children>
        <TextField fx:id="userInput"
                   layoutY="558.0"
                   onAction="#handleUserInput"
                   prefHeight="41.0" prefWidth="324.0"
                   AnchorPane.bottomAnchor="1.0" AnchorPane.leftAnchor="1.0"/>
        <Button fx:id="sendButton"
                layoutX="324.0" layoutY="558.0"
                mnemonicParsing="false"
                onAction="#handleUserInput"
                prefHeight="41.0" prefWidth="76.0"
                text="Send"
                AnchorPane.bottomAnchor="1.0" AnchorPane.rightAnchor="1.0"/>
        <ScrollPane fx:id="scrollPane"
                    hbarPolicy="NEVER" vvalue="1.0"
                    prefHeight="557.0" prefWidth="400.0"
                    AnchorPane.topAnchor="1.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
            <content>
                <VBox fx:id="dialogContainer" prefWidth="388.0"/>
            </content>
        </ScrollPane>
    </children>
</AnchorPane>
