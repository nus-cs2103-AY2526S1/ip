<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.shape.Circle?>

<fx:root alignment="TOP_RIGHT" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" prefWidth="400.0" stylesheets="@../css/dialog-box.css" type="javafx.scene.layout.HBox" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <Label id="dialog" fx:id="dialog" minHeight="-Infinity" text="Label" wrapText="true">
         <HBox.margin>
            <Insets left="20.0" right="20.0" />
         </HBox.margin>
         <padding>
            <Insets bottom="8.0" left="8.0" right="8.0" top="8.0" />
         </padding></Label>
      <StackPane alignment="BOTTOM_RIGHT" prefHeight="40.0" prefWidth="40.0">
         <HBox.margin>
            <Insets />
         </HBox.margin>
         <children>
            <Circle fx:id="profileCircle" fill="#f0f0f000" radius="20.0" stroke="BLACK" strokeType="INSIDE" />
         </children>
      </StackPane>
   </children>
   <padding>
      <Insets bottom="15.0" left="5.0" right="5.0" top="15.0" />
   </padding>
</fx:root>
