<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>

<fx:root type="javafx.scene.layout.HBox"
         xmlns="http://javafx.com/javafx/17"
         xmlns:fx="http://javafx.com/fxml/1"
         alignment="TOP_RIGHT"
         stylesheets="@/css/dialog-box.css"
         prefWidth="400.0">
    <children>
        <Label fx:id="dialog" text="..." wrapText="true" minHeight="-Infinity">
            <HBox.margin>
                <Insets left="7.0" right="7.0"/>
            </HBox.margin>
            <padding>
                <Insets top="6.0" right="6.0" bottom="6.0" left="6.0"/>
            </padding>
        </Label>
        <ImageView fx:id="displayPicture" fitWidth="99.0" fitHeight="99.0" pickOnBounds="true" preserveRatio="true"/>
    </children>
</fx:root>
